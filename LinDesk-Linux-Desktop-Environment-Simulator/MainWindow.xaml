<Window x:Class="LinDesk_Linux_Desktop_Environment_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LinDesk_Linux_Desktop_Environment_Simulator"
        mc:Ignorable="d"
        RenderOptions.BitmapScalingMode="LowQuality"
        RenderOptions.EdgeMode="Aliased"
        Title="LinDesk - Linux Desktop Enviroment Simulator"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">


    <Grid>

        <!-- Boot Screen -->
        <Grid x:Name="BootScreen" Visibility="Collapsed">
            <TextBox x:Name="BootOutput"
                     Background="Black"
                     Foreground="Lime"
                     FontFamily="Consolas"
                     IsReadOnly="True"
                     BorderThickness="0"
                     VerticalScrollBarVisibility="Hidden"
                     HorizontalScrollBarVisibility="Hidden"/>
        </Grid>

        <!-- Login Screen -->
        <Grid x:Name="LoginScreen"
              Visibility="Collapsed">
            <Grid.Background>
                <ImageBrush ImageSource="/images/LoginBackground.png" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid.Background>

            <!-- Centered translucent card -->
            <Border Width="420"
                    Padding="36"
                    CornerRadius="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" Background="#1AFFFFFF">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.5"/>
                </Border.Effect>

                <StackPanel Height="332">
                    <!-- Logo -->
                    <Ellipse Width="92" Height="87" HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/images/LDlogo.png"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <TextBlock Text="Lindesk"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,2"/>

                    <TextBlock Text="Learning to code is useful no matter what your career ambitions are."
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#DDE6F0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,18"/>

                    <!-- Username -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock Text="Username" Foreground="#BFC8D6" FontSize="12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="1" Name="UsernameBox" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#6B6B6B" Margin="28,6,0,0"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Margin="0,4,0,12">
                        <TextBlock Text="Password" Foreground="#BFC8D6" FontSize="12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox Grid.Column="1" x:Name="pass" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#6B6B6B" Margin="28,6,0,0"/>
                    </StackPanel>

                    <!-- Login button -->
                    <Button Name="LoginButton" Click="LoginButton_Click" Height="38" Margin="0,4,0,6" FontWeight="Bold" Foreground="White" BorderThickness="0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6D5BFF" Offset="0"/>
                                <GradientStop Color="#8A5BFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Border CornerRadius="18" Background="Transparent" Padding="8,4">
                            <TextBlock Text="LOG IN" HorizontalAlignment="Center"/>
                        </Border>
                    </Button>

                    <TextBlock Name="LoginStatus" Text="" Foreground="#FFD1D1" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,6,0,6"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                        <TextBlock Text=" " />
                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>


        <!-- Desktop Screen -->
        <Grid x:Name="DesktopScreen" Visibility="Visible">

            <!-- Background -->
            <Image Source="/images/pc_background.png" Stretch="Fill"/>

            <!-- Bottom-left buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,0">

                <Button Name="PowerButton"
                        Width="66"
                        Height="66"
                        BorderBrush="{x:Null}"
                        Foreground="{x:Null}"
                        Click="PowerButton_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/images/power_button.png"/>
                    </Button.Background>
                </Button>

                <Button Name="TerminalButton"
                        Width="66"
                        Height="66"
                        BorderBrush="{x:Null}"
                        Click="TerminalButton_Click">
                    <Button.Background>
                        <ImageBrush TileMode="None"
                                    Stretch="UniformToFill"
                                    ImageSource="/images/Terminal_Icon.png"/>
                    </Button.Background>
                </Button>
                <Button Name="FileExplorer"
                        Width="66"
                        Height="66"
                        Content="FE"
                        BorderBrush="{x:Null}"
                        Background="Gray">
                </Button>
                <Button Name="MusicPlayer"
                        Width="66"
                        Height="66"
                        BorderBrush="{x:Null}" Click="MusicPlayer_Click" >
                    <Button.Background>
                        <ImageBrush TileMode="None"
                                    Stretch="UniformToFill"
                                    ImageSource="/images/Music_Icon.png"/>
                    </Button.Background>
                </Button>
            </StackPanel>

            <!-- Power options popup -->
            <Grid x:Name="PowerOptions"
                  Visibility="Collapsed"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Left"
                  Opacity="0"
                  Margin="0,0,0,66"
                  Width="170"
                  Height="180">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border  
                CornerRadius="30" 
                Background="#1e1e1e"
                Grid.RowSpan="3">
                </Border>
                <Button x:Name="Shutdown"
                        Grid.Row="0"
                        Content="Shutdown"
                        Background="Transparent"
                        Foreground="WhiteSmoke"
                        Click="Shutdown_Click"
                        BorderThickness="0"/>

                <Button x:Name="Restart"
                        Grid.Row="1"
                        Content="Restart"
                        Background="Transparent"
                        Foreground="WhiteSmoke"
                        Click="Restart_Click"
                        BorderThickness="0"/>

                <Button x:Name="Sleep"
                        Grid.Row="2"
                        Content="Sleep"
                        Background="Transparent"
                        Foreground="WhiteSmoke"
                        Click="Sleep_Click"
                        BorderThickness="0"/>
            </Grid>

            <!-- Terminal window -->
                <Grid x:Name="Terminal"
                  Visibility="Collapsed"
                  Width="1000"
                  Height="600"
                  Opacity="0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                </Grid.RenderTransform>

                <Border  
                  CornerRadius="30" 
                  Background="#1e1e1e">
                </Border>
                <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Grid.Resources>
                            <Style TargetType="{x:Type Paragraph}">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </Grid.Resources>
                        <RichTextBox 
                        Name="TerminalHistory"
                        Grid.Row="0"
                        Background="{x:Null}"
                        FontSize="24"
                        Foreground="Lime"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        BorderThickness="0"
                        VerticalScrollBarVisibility="Hidden"
                        HorizontalScrollBarVisibility="Hidden"
                        Padding="8"/>

                        <RichTextBox 
                        Name="TerminalBox"
                        Grid.Row="1"
                        FontFamily="Consolas"
                        FontSize="24"
                        Foreground="Lime"
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalScrollBarVisibility="Hidden"
                        HorizontalScrollBarVisibility="Hidden"
                        Padding="8,0,8,0"/>
                    </Grid>
                </Grid>
            <!--  Music Player -->
            <Grid Name="MP"
                  Visibility="Visible"
                  Width="1000"
                  Height="600"
                  Opacity="1"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                </Grid.RenderTransform>
                <Border  
                      CornerRadius="30" 
                      Background="#1e1e1e">
                </Border>
                <Image Name="MusicPicture" Source="/images/MusicPictures/QM.png" VerticalAlignment="Top" HorizontalAlignment="Center" Height="300" Margin="0,60,0,0"/>
                <Slider Name="MusicSlider" Margin="100,460,100,126" Foreground="Red"/>
                <Button Name="Rewind" Content="Rewind" Margin="89,504,716,38"/>
                <Button Name="PlayPause" Content="Play" Margin="402,504,403,38" Click="PlayPause_Click"/>
                <Button Name="Forward" Content="Forward" Margin="716,504,89,38"/>
                <Label Name="Time" Content="00:00/00:00" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,130,155" Foreground="White"/>
                <Label Name="SongName" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,155" Foreground="White" Content="Song Title"/>
                <Label Name="ArtistName" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="100,155" Foreground="White" Content="Artist Name"/>
            </Grid> 
            <!--  Nano Content Editor -->
            <Grid Name="NanoEditor"
                  Visibility="Collapsed"
                  Width="1000"
                  Height="600"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" KeyDown="NanoEditor_KeyDown">
                <Border  
                      CornerRadius="30" 
                      Background="#1e1e1e">
                </Border>
                <Label Name="FileName"
                       Content="FileName"
                       FontSize="16"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Center"
                       Foreground="White">
                </Label>
                <Label Name="Command"
                       Content="Save: F10"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Foreground="White"
                       Padding="30,0,0,30">
                </Label>
                <TextBox Name="NanoContent"
                         Background="Transparent"
                         Foreground="Lime"
                         FontFamily="Consolas"
                         FontSize="32"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Hidden"
                         HorizontalScrollBarVisibility="Hidden"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"
                         Margin="5,35,5,70"
                         AcceptsReturn="True"
                         TextWrapping="Wrap">
                </TextBox>
                <Label Name="NewFileWarning"
                       Content="NewFile"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,45"
                       Foreground="White"
                       FontSize="16"
                       Visibility="Collapsed">
                </Label>
            </Grid>
            <!-- Debug labels on the right -->
            <StackPanel HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,40,20,0"
                        Width="250"
                        Visibility="Collapsed">
                <Label Name="CommandLabel"
                       Content="CommandLabel"
                       FontSize="16"/>
                <Label Name="PrefixLabel"
                       Content="Prefix"
                       FontSize="16"/>
                <Label Name="DirectoryLabel"
                       Content="DirectoryLabel"
                       FontSize="16"/>
                <Label Name="DebugLabel"
                       Content="DebugLabel"
                       FontSize="16"
                       Width="250"/>
                <Label Name="CurrentDirectoryDebug"
                       Content="CurrentDirectory" 
                       HorizontalAlignment="Left" 
                       Margin="1266,170,0,0" 
                       VerticalAlignment="Top" 
                       Width="250"
                       FontSize="16"/>
            </StackPanel>

        </Grid>

        <!-- Sleep Screen -->
        <Grid x:Name="SleepMode"
              Visibility="Collapsed"
              MouseLeftButtonDown="SleepScreen_MouseLeftButtonDown">
            <Rectangle Fill="#FF2D2828"/>
            <Label Content="THIS IS A TEMPORARY SLEEP MODE SCREEN!!!"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="60"/>
        </Grid>

    </Grid>
</Window>
