<Window x:Class="LinDesk_Linux_Desktop_Environment_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LinDesk_Linux_Desktop_Environment_Simulator"
        RenderOptions.BitmapScalingMode="LowQuality"
        RenderOptions.EdgeMode="Aliased"
        mc:Ignorable="d"
        Title="MainWindow"  Height="1080" Width="1920">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="191*"/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>

        <!-- Boot Screen -->
        <Grid x:Name="BootScreen" Visibility="Collapsed" Grid.ColumnSpan="2">

            <TextBox x:Name="BootOutput"
                 Background="Black"
                 Foreground="Lime"
                 FontFamily="Consolas"
                 IsReadOnly="True"/>
        </Grid>

        <!-- Login Screen -->
        <Grid x:Name="LoginScreen" Visibility="Visible" Grid.ColumnSpan="2">
            <Grid.Background>
                <ImageBrush Stretch="Fill" ImageSource="/images/loginBckBlurred.jpg"/>
            </Grid.Background>
            <Button Name="LoginButton" Content="" HorizontalAlignment="Left" Margin="1030,565,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Click="LoginButton_Click" Height="33" BorderThickness="0,1,1,1" Width="58" BorderBrush="#FF595B62">
                <Button.Background>
                    <ImageBrush Stretch="UniformToFill" ImageSource="/images/sipka login.jpg" TileMode="None">
                        <ImageBrush.RelativeTransform>
                            <TransformGroup>
                                <ScaleTransform CenterY="0.5" CenterX="0.495" ScaleX="5" ScaleY="3"/>
                                <SkewTransform CenterX="0.495" CenterY="0.5"/>
                                <RotateTransform CenterX="0.495" CenterY="0.5"/>
                                <TranslateTransform X="0"/>
                            </TransformGroup>
                        </ImageBrush.RelativeTransform>
                    </ImageBrush>
                </Button.Background>
            </Button>
            <TextBlock HorizontalAlignment="Center" Margin="0,171,0,0" TextWrapping="Wrap" Text="Lindesk Login" VerticalAlignment="Top" Height="33" Width="120" FontSize="24"/>
            <TextBox Name="UsernameBox"  Margin="888,504,907,532"   VerticalContentAlignment="Center" Width="125" BorderBrush="DarkGray" Height="28" Foreground="White" FontSize="13" FontWeight="Medium" FontFamily="Montserrat" Background="Transparent" BorderThickness="0,0,0,2" RenderTransformOrigin="-3.756,-0.742" />

            <PasswordBox Name="PasswordBox" HorizontalAlignment="Left" Margin="884,564,0,0"   VerticalAlignment="Top" Width="125" BorderBrush="#FF595B62" Height="34"/>
            <TextBlock x:Name="LoginStatus" HorizontalAlignment="Left" Margin="251,347,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="209"/>
            <TextBlock Name="Username" Foreground="DarkGray"  Margin="888,457,916,583"  Text="Username"/>
        </Grid>
        <!-- Desktop Screen -->
        <Grid x:Name="DesktopScreen" Visibility="Collapsed" Grid.ColumnSpan="2">
            <Image Source="/images/pc_background.png" Stretch="Fill"/>
            <Button Name="PowerButton" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="66" Width="66" BorderBrush="{x:Null}" Foreground="{x:Null}" Grid.ColumnSpan="2" Click="PowerButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/images/power_button.png"/>
                </Button.Background>
            </Button>
            <Button Name="TerminalButton" HorizontalAlignment="Left" Margin="71,0,0,0" VerticalAlignment="Bottom" Width="66" Height="66" BorderBrush="{x:Null}" Click="TerminalButton_Click">
                <Button.Background>
                    <ImageBrush TileMode="None" Stretch="UniformToFill" ImageSource="/images/Terminal_Icon.png"/>
                </Button.Background>
            </Button>
            <Grid x:Name="PowerOptions" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="0,-72,0,0" Width="170" Height="180">


                <Button x:Name="Shutdown" Content="Shutdown" Height="60" Width="170" BorderBrush="Black" Margin="0,0,0,120" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FF5E5656" Click="Shutdown_Click"/>
                <Button x:Name="Restart" Content="Restart" HorizontalAlignment="Center" VerticalAlignment="Center" Height="60" Width="170" Background="#FF5E5656" Click="Restart_Click"/>
                <Button x:Name="Sleep" Content="Sleep" HorizontalAlignment="Center" Margin="0,120,0,0" VerticalAlignment="Top" Height="60" Width="170" Background="#FF5E5656" Click="Sleep_Click"/>

            </Grid>
            <Grid x:Name="Terminal" Visibility="Visible" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Rectangle Name="TerminalWindow" HorizontalAlignment="Center" Height="600" Stroke="Black" VerticalAlignment="Center" Width="1000" Fill="#FF2D2828"/>
                <TextBox Name="TerminalText" HorizontalAlignment="Left" TextWrapping="Wrap" Text="" FontSize="20" VerticalAlignment="Center" Width="816" Height="600" Background="#FF2D2828" Foreground="Lime" Margin="186,0,0,0" KeyDown="Terminal_KeyDown"/>
                <TextBox Name="LinuxTextWriter" HorizontalAlignment="Left" TextWrapping="Wrap" Text=" demo@LinDesk:~$" FontSize="20" VerticalAlignment="Center" Height="600" Width="181" Background="#FF2D2828" Foreground="Lime"/>

            </Grid>

        </Grid>
        <!-- Sleep Screen -->
        <Grid x:Name="SleepMode" Visibility="Collapsed" Grid.ColumnSpan="2" MouseLeftButtonDown="SleepScreen_MouseLeftButtonDown">

            <Rectangle HorizontalAlignment="Center" Height="1064" Stroke="Black" VerticalAlignment="Center" Width="1920" Fill="#FF2D2828"/>
            <Label Content="THIS IS A TEMPORARY SLEEP MODE SCREEN!!!" HorizontalAlignment="Center" VerticalAlignment="Center" Height="100" Width="1282" FontSize="60"/>



        </Grid>
    </Grid>
</Window>
