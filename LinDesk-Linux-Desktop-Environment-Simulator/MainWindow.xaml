<Window x:Class="LinDesk_Linux_Desktop_Environment_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LinDesk_Linux_Desktop_Environment_Simulator"
        mc:Ignorable="d"
        RenderOptions.BitmapScalingMode="LowQuality"
        RenderOptions.EdgeMode="Aliased"
        Title="MainWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- Boot Screen -->
        <Grid x:Name="BootScreen" Visibility="Collapsed">
            <TextBox x:Name="BootOutput"
                     Background="Black"
                     Foreground="Lime"
                     FontFamily="Consolas"
                     IsReadOnly="True"
                     BorderThickness="0"
                     VerticalScrollBarVisibility="Hidden"
                     HorizontalScrollBarVisibility="Hidden"/>
        </Grid>

        <!-- Login Screen -->
        <Grid x:Name="LoginScreen" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="220">
                <TextBlock Text="Lindesk Login"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBox Name="UsernameBox"
                         Text="Username"
                         Width="120"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,10"/>

                <TextBox Name="PasswordBox"
                         Text="Password"
                         Width="120"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,15"
                         BorderBrush="#FF595B62"/>

                <Button Name="LoginButton"
                        Content="Login"
                        Width="120"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15"
                        Click="LoginButton_Click"/>

                <TextBlock Name="LoginStatus"
                           Text=""
                           TextWrapping="Wrap"
                           Width="209"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Desktop Screen -->
        <Grid x:Name="DesktopScreen" Visibility="Visible">

            <!-- Background -->
            <Image Source="/images/pc_background.png" Stretch="Fill"/>

            <!-- Bottom-left buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,0">

                <Button Name="PowerButton"
                        Width="66"
                        Height="66"
                        BorderBrush="{x:Null}"
                        Foreground="{x:Null}"
                        Click="PowerButton_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/images/power_button.png"/>
                    </Button.Background>
                </Button>

                <Button Name="TerminalButton"
                        Width="66"
                        Height="66"
                        BorderBrush="{x:Null}"
                        Click="TerminalButton_Click">
                    <Button.Background>
                        <ImageBrush TileMode="None"
                                    Stretch="UniformToFill"
                                    ImageSource="/images/Terminal_Icon.png"/>
                    </Button.Background>
                </Button>
            </StackPanel>

            <!-- Power options popup -->
            <Grid x:Name="PowerOptions"
                  Visibility="Visible"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Left"
                  Opacity="0"
                  Margin="0,0,0,66"
                  Width="170"
                  Height="180">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border  
                CornerRadius="30" 
                Background="#1e1e1e"
                Grid.RowSpan="3">
                </Border>
                <Button x:Name="Shutdown"
                        Grid.Row="0"
                        Content="Shutdown"
                        Background="Transparent"
                        Foreground="WhiteSmoke"
                        Click="Shutdown_Click"
                        BorderThickness="0"/>

                <Button x:Name="Restart"
                        Grid.Row="1"
                        Content="Restart"
                        Background="Transparent"
                        Foreground="WhiteSmoke"
                        Click="Restart_Click"
                        BorderThickness="0"/>

                <Button x:Name="Sleep"
                        Grid.Row="2"
                        Content="Sleep"
                        Background="Transparent"
                        Foreground="WhiteSmoke"
                        Click="Sleep_Click"
                        BorderThickness="0"/>
            </Grid>

            <!-- Terminal window -->
                <Grid x:Name="Terminal"
                  Visibility="Collapsed"
                  Width="1000"
                  Height="600"
                  Opacity="0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                </Grid.RenderTransform>

                <Border  
                  CornerRadius="30" 
                  Background="#1e1e1e">
                </Border>
                <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Grid.Resources>
                            <Style TargetType="{x:Type Paragraph}">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </Grid.Resources>
                        <RichTextBox 
                        Name="TerminalHistory"
                        Grid.Row="0"
                        Background="{x:Null}"
                        FontSize="24"
                        Foreground="Lime"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        BorderThickness="0"
                        VerticalScrollBarVisibility="Hidden"
                        HorizontalScrollBarVisibility="Hidden"
                        Padding="8"/>

                        <RichTextBox 
                        Name="TerminalBox"
                        Grid.Row="1"
                        FontFamily="Consolas"
                        FontSize="24"
                        Foreground="Lime"
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalScrollBarVisibility="Hidden"
                        HorizontalScrollBarVisibility="Hidden"
                        Padding="8,0,8,0"/>
                    </Grid>
                </Grid>
            <!-- Debug labels on the right -->
            <StackPanel HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,40,20,0"
                        Width="250"
                        Visibility="Collapsed">
                <Label Name="CommandLabel"
                       Content="CommandLabel"
                       FontSize="16"/>
                <Label Name="PrefixLabel"
                       Content="Prefix"
                       FontSize="16"/>
                <Label Name="DirectoryLabel"
                       Content="DirectoryLabel"
                       FontSize="16"/>
                <Label Name="DebugLabel"
                       Content="DebugLabel"
                       FontSize="16"
                       Width="250"/>
                <Label Name="CurrentDirectoryDebug"
                       Content="CurrentDirectory" 
                       HorizontalAlignment="Left" 
                       Margin="1266,170,0,0" 
                       VerticalAlignment="Top" 
                       Width="250"
                       FontSize="16"/>
            </StackPanel>

        </Grid>

        <!-- Sleep Screen -->
        <Grid x:Name="SleepMode"
              Visibility="Collapsed"
              MouseLeftButtonDown="SleepScreen_MouseLeftButtonDown">
            <Rectangle Fill="#FF2D2828"/>
            <Label Content="THIS IS A TEMPORARY SLEEP MODE SCREEN!!!"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="60"/>
        </Grid>

    </Grid>
</Window>
