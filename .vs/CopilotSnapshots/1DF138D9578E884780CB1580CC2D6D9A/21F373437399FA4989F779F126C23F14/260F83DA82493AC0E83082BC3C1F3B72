<Window x:Class="LinDesk_Linux_Desktop_Environment_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LinDesk_Linux_Desktop_Environment_Simulator"
        RenderOptions.BitmapScalingMode="LowQuality"
        RenderOptions.EdgeMode="Aliased"
        mc:Ignorable="d"
        Title="MainWindow"  Height="1080" Width="1920">
    <Window.Resources>
        <!-- Styles and brushes for modern login UI -->
        <Style x:Key="UnderlineTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6 6 6 8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="UnderlinePasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6 6 6 8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#7C5CFF"/>
            <GradientStop Offset="1" Color="#6A43FF"/>
        </LinearGradientBrush>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="191*"/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>

        <!-- Boot Screen -->
        <Grid x:Name="BootScreen" Visibility="Collapsed" Grid.ColumnSpan="2">

            <TextBox x:Name="BootOutput"
                 Background="Black"
                 Foreground="Lime"
                 FontFamily="Consolas"
                 IsReadOnly="True"/>
        </Grid>

        <!-- Login Screen -->
        <Grid x:Name="LoginScreen" Visibility="Visible" Grid.ColumnSpan="3" Margin="5,0,-5,0">
            <Grid.Background>
                <ImageBrush ImageSource="/images/pc_background.png"/>
            </Grid.Background>
            <!-- Centered login panel with fixed size -->
            <Border Width="520" Height="281" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" Opacity="0.98">
                <UIElement.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </UIElement.RenderTransform>
                <!-- Use a Canvas so controls can be freely repositioned in the Visual Studio designer -->
                <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <TextBlock Text="LinDesk Login" FontSize="24" FontWeight="Bold" Width="320" Canvas.Left="32" Canvas.Top="10" FontFamily="Arial"/>
                    <TextBox x:Name="UsernameBox" FontFamily="Arial" Width="320" Height="32" Canvas.Left="32" Canvas.Top="48" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" BorderBrush="LightGray" FontSize="24" />
                    <PasswordBox Name="PasswordBox" Width="320" FontFamily="Arial" Height="32" Canvas.Left="32" Canvas.Top="92" BorderBrush="LightGray" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="24"/>
                    <!-- Login button placed immediately to the right of PasswordBox; show image from /images inside the button -->
                    <Button x:Name="LoginButton" Width="50" Height="33" Canvas.Left="357" Canvas.Top="92" Click="LoginButton_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="2" BorderBrush="LightGray ">
                        <Button.Background>
                            <ImageBrush ImageSource="/images/icons8-login-48.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button.Background>
                        <Image Source="/images/Terminal_Icon.png" Stretch="Uniform" Height="40" RenderTransformOrigin="4.386,3.955" Width="46" >
                            <Image.OpacityMask>
                                <ImageBrush/>
                            </Image.OpacityMask>

                        </Image>
                    </Button>
                    <TextBlock Name="LoginStatus" Text="" Foreground="Red" TextWrapping="Wrap" Width="448" Canvas.Left="32" Canvas.Top="136" />
                </Canvas>
            </Border>
        </Grid>
        <!-- Desktop Screen -->
        <Grid x:Name="DesktopScreen" Visibility="Collapsed" Grid.ColumnSpan="2">
            <Image Source="/images/pc_background.png" Stretch="Fill"/>
            <Button Name="PowerButton" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="66" Width="66" BorderBrush="{x:Null}" Foreground="{x:Null}" Grid.ColumnSpan="2" Click="PowerButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/images/power_button.png"/>
                </Button.Background>
            </Button>
            <Button Name="TerminalButton" HorizontalAlignment="Left" Margin="71,0,0,0" VerticalAlignment="Bottom" Width="66" Height="66" BorderBrush="{x:Null}" Click="TerminalButton_Click">
                <Button.Background>
                    <ImageBrush TileMode="None" Stretch="UniformToFill" ImageSource="/images/Terminal_Icon.png"/>
                </Button.Background>
            </Button>
            <Grid x:Name="PowerOptions" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="0,-72,0,0" Width="170" Height="180">


                <Button x:Name="Shutdown" Content="Shutdown" Height="60" Width="170" BorderBrush="Black" Margin="0,0,0,120" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FF5E5656" Click="Shutdown_Click"/>
                <Button x:Name="Restart" Content="Restart" HorizontalAlignment="Center" VerticalAlignment="Center" Height="60" Width="170" Background="#FF5E5656" Click="Restart_Click"/>
                <Button x:Name="Sleep" Content="Sleep" HorizontalAlignment="Center" Margin="0,120,0,0" VerticalAlignment="Top" Height="60" Width="170" Background="#FF5E5656" Click="Sleep_Click"/>

            </Grid>
            <Grid x:Name="Terminal" Visibility="Visible" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Rectangle Name="TerminalWindow" HorizontalAlignment="Center" Height="600" Stroke="Black" VerticalAlignment="Center" Width="1000" Fill="#FF2D2828"/>
                <TextBox Name="TerminalBox" FontFamily="Consolas" FontSize="16" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" KeyDown="TerminalBox_KeyDown" PreviewKeyDown="TerminalBox_PreviewKeyDown" PreviewMouseDown="TerminalBox_PreviewMouseDown" SelectionChanged="TerminalBox_SelectionChanged" Background="#FF2D2828"/>
            </Grid>

        </Grid>
        <!-- Sleep Screen -->
        <Grid x:Name="SleepMode" Visibility="Collapsed" Grid.ColumnSpan="2" MouseLeftButtonDown="SleepScreen_MouseLeftButtonDown">

            <Rectangle HorizontalAlignment="Center" Height="1064" Stroke="Black" VerticalAlignment="Center" Width="1920" Fill="#FF2D2828"/>
            <Label Content="THIS IS A TEMPORARY SLEEP MODE SCREEN!!!" HorizontalAlignment="Center" VerticalAlignment="Center" Height="100" Width="1282" FontSize="60"/>



        </Grid>
    </Grid>
</Window>
